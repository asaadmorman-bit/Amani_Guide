<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Amani Governed Workspace Platform</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen font-sans">

  <div class="max-w-7xl mx-auto px-4 py-8 grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <div class="lg:col-span-2 space-y-6">
      <header class="border-b border-slate-800 pb-4">
        <h1 class="text-3xl font-extrabold tracking-tight text-indigo-400">🛰️ Amani Workspace Control Tower</h1>
        <p class="text-sm text-slate-400">Zero-Trust Multi-Persona Governance Control Mesh Engine</p>
      </header>

      <div class="bg-slate-800 p-6 rounded-xl border border-slate-700 shadow-xl space-y-4">
        <h3 class="text-lg font-bold text-slate-200">🛠️ Synchronize Action Configuration Blueprint</h3>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-400 uppercase mb-1">Active Actor Identity</label>
            <input id="formUser" type="text" value="professor_amani" class="w-full bg-slate-900 border border-slate-700 rounded p-2 focus:outline-none focus:border-indigo-500 text-sm">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-400 uppercase mb-1">Target Persona Clearance Context</label>
            <select id="formRole" class="w-full bg-slate-900 border border-slate-700 rounded p-2 focus:outline-none focus:border-indigo-500 text-sm">
              <option value="Academic_Faculty">Academic Faculty (FERPA Controls)</option>
              <option value="Family_Lead">Family Lead / Parent (COPPA Controls)</option>
              <option value="System_Architect">System Architect (Enterprise Security)</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase mb-1">Automation Configuration Manifest (YAML)</label>
          <textarea id="formYaml" rows="6" class="w-full bg-slate-900 border border-slate-700 rounded p-2 focus:outline-none focus:border-indigo-500 text-sm font-mono text-emerald-400">student_roster: "active_grades_v1"
mcp_server: "canvas_sync"
pii_masking: "disabled"</textarea>
        </div>

        <button onclick="dispatchConfigurationSync()" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-4 rounded transition text-sm shadow-md">
          Execute Real-Time Policy Verification Pass
        </button>
      </div>

      <div class="bg-slate-800 p-6 rounded-xl border border-slate-700 shadow-xl">
        <h3 class="text-lg font-bold text-slate-200 mb-3">🖥️ Platform Interceptor Trace Summary</h3>
        <div id="outputTrace" class="bg-slate-950 p-4 rounded border border-slate-800 text-slate-300 font-mono text-xs h-48 overflow-y-auto whitespace-pre-wrap">Awaiting operational command execution matrix signature verification down the wire...</div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="bg-slate-800 p-6 rounded-xl border border-slate-700 shadow-xl min-h-[600px] flex flex-col justify-between">
        <div>
          <div class="flex justify-between items-center border-b border-slate-700 pb-3 mb-4">
            <h3 class="text-md font-bold uppercase tracking-wider text-amber-400">🛡️ Immutable Audit Evidence</h3>
            <span class="bg-amber-500/10 text-amber-400 text-[10px] font-bold px-2 py-0.5 rounded border border-amber-500/20">LIVE ACTIVE</span>
          </div>
          <p class="text-xs text-slate-400 mb-4">Dynamic monitoring feeds pulling secure transactions from the relational Wasm vault ledger.</p>
          
          <div id="auditTimeline" class="space-y-3 max-h-[480px] overflow-y-auto pr-1">
            <div class="text-xs text-slate-500 italic text-center py-8">Gathering cryptographic ledger artifacts...</div>
          </div>
        </div>

        <button onclick="fetchAuditorLedgerHistory()" class="w-full bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs font-bold py-2 px-4 rounded transition mt-4">
          Force Ledger Manual Refresh Check
        </button>
      </div>
    </div>

  </div>

  <script>
    const SERVER_URL = 'http://127.0.0.1:3000/api';

    // Dispatches configuration blocks right into your working server routes
    async function dispatchConfigurationSync() {
      const trace = document.getElementById('outputTrace');
      trace.innerText = "⚡ Routing telemetry package down the security middleware validation pipeline...";

      const payload = {
        yamlContent: document.getElementById('formYaml').value,
        userCredentials: {
          username: document.getElementById('formUser').value,
          role: document.getElementById('formRole').value
        }
      };

      try {
        const response = await fetch(`${SERVER_URL}/tandem-build`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        
        const data = await response.json();
        
        if (response.ok && data.success) {
          if (data.selfHealed) {
            trace.innerHTML = `<span class="text-amber-400">${data.summary}\n\n${data.logs}\n\n🤖 HEALED MANIFEST CONFIG:\n${data.healedYaml}</span>`;
          } else {
            trace.innerHTML = `<span class="text-emerald-400">${data.summary}\n\n${data.logs}</span>`;
          }
        } else {
          trace.innerHTML = `<span class="text-rose-400">🚨 Compliance Boundary Halt!\nStatus: ${response.status}\nError: ${data.error || 'Validation Block'}\n\nLogs:\n${data.logs || 'Execution rejected due to data policies.'}</span>`;
        }
      } catch (err) {
        trace.innerHTML = `<span class="text-rose-500">❌ Local Connection Error: Ensure backend is listening via npm run server. [${err.message}]</span>`;
      }
      
      // Auto-reload ledger view dynamically whenever data changes
      fetchAuditorLedgerHistory();
    }

    // Fetches security ledger reports straight out of your WebAssembly PGlite storage layer
    async function fetchAuditorLedgerHistory() {
      const container = document.getElementById('auditTimeline');
      
      try {
        const response = await fetch(`${SERVER_URL}/auditor-evidence`);
        const data = await response.json();
        
        if (!data.success || !data.evidence.historicalAuditTrails.length) {
          container.innerHTML = `<div class="text-xs text-slate-500 italic text-center py-8">Ledger storage currently empty. Run transactions to generate trails.</div>`;
          return;
        }

        container.innerHTML = data.evidence.historicalAuditTrails.reverse().map(log => {
          const badgeColor = log.status === 'COMPLIANT_SUCCESS' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 'bg-rose-500/10 text-rose-400 border-rose-500/20';
          const stamp = new Date(log.timestamp).toLocaleTimeString();
          
          return `
            <div class="bg-slate-900/60 p-3 rounded border border-slate-800 space-y-1.5 text-xs shadow-sm">
              <div class="flex justify-between items-center">
                <span class="font-bold text-slate-300 truncate max-w-[120px]">${log.event}</span>
                <span class="text-[10px] text-slate-500 font-mono">${stamp}</span>
              </div>
              <div class="flex justify-between text-[11px] text-slate-400">
                <span>User: <strong class="text-indigo-400">${log.operator}</strong> (${log.role})</span>
                <span class="border rounded px-1.5 py-0.5 text-[10px] uppercase font-bold ${badgeColor}">${log.status.replace('_',' ')}</span>
              </div>
              <div class="text-[10px] text-slate-600 font-mono truncate">Hash: ${log.specIntegrityHash.substring(0,24)}...</div>
            </div>
          `;
        }).join('');

      } catch (err) {
        container.innerHTML = `<div class="text-xs text-rose-400/70 text-center py-8">⚠️ Unable to fetch evidence data.</div>`;
      }
    }

    // Connect auto-polling loop: updates administrative ledger dashboard panel view every 3 seconds
    fetchAuditorLedgerHistory();
    setInterval(fetchAuditorLedgerHistory, 3000);
  </script>
</body>
</html>